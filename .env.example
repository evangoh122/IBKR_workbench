# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real file.

# ── IBKR TWS / Gateway connection ────────────────────────────────────────────
TWS_HOST=127.0.0.1
TWS_PORT=7497          # 7497 = TWS paper, 7496 = TWS live, 4002 = Gateway live
TWS_CLIENT_ID=1

# ── ETL behaviour ─────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
OPTIONS_EXPIRY_CYCLES=2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR

# ── DuckDB / vector store ─────────────────────────────────────────────────────
DUCKDB_PATH=./data/vectors.duckdb

# ── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=          # https://polygon.io/dashboard/api-keys
POLYGON_BARS_TIMESPAN=day # day | minute | hour
POLYGON_BARS_LOOKBACK=7   # days of history to fetch per run

# ── Chat AI ───────────────────────────────────────────────────────────────────
# Set CHAT_PROVIDER to one of: deepseek | mimo | openai | anthropic | ollama
CHAT_PROVIDER=deepseek
CHAT_MODEL=                      # optional — overrides the provider default

# DeepSeek (default) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Xiaomi MiMo — run locally via Ollama (free) or a hosted endpoint
MIMO_API_KEY=                    # leave blank for Ollama; set key for hosted
MIMO_BASE_URL=http://localhost:11434/v1

# OpenAI (GPT-4o / GPT-4o-mini) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Ollama local (no key, fully offline) — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2            # any model pulled via: ollama pull <model>

# ── Paths (optional overrides) ────────────────────────────────────────────────
DB_PATH=./data/ibkr.duckdb
TICKERS_YAML=config/tickers.yaml
