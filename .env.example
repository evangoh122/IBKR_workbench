# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real file.

# ── IBKR TWS / Gateway connection ────────────────────────────────────────────
TWS_HOST=127.0.0.1
TWS_PORT=4001          # 4001 = Gateway live, 7496 = TWS live, 7497 = TWS paper
TWS_CLIENT_ID=1

# ── ETL behaviour ─────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
OPTIONS_EXPIRY_CYCLES=2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR

# ── DuckDB / vector store ─────────────────────────────────────────────────────
DUCKDB_PATH=./data/vectors.duckdb

# ── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=          # https://polygon.io/dashboard/api-keys
POLYGON_BARS_TIMESPAN=day # day | minute | hour
POLYGON_BARS_LOOKBACK=9500 # days of history to fetch per run
# Watchlist: blank = all 11k stocks (paid plan). Free tier: set to comma-separated list e.g. SPY,AAPL,...
POLYGON_TICKERS=
POLYGON_RATE_DELAY=0.1    # seconds between requests (paid: 0.1, free tier: 15)
# Options snapshots: max contracts stored per ticker (paid plan default: 2000)
POLYGON_OPTIONS_MAX_CONTRACTS=2000
# Option bars: curated liquid list — all-stocks option bars takes 300+ hrs even on paid
POLYGON_OPTION_BARS_TICKERS=SPY,QQQ,IWM,DIA,GLD,SLV,TLT,HYG,XLF,XLE,XLK,XLV,EEM,EFA,AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,JPM,BAC,GS,MS,WFC,AMD,INTC,QCOM,AVGO,MU,AMAT,V,MA,PYPL,JNJ,PFE,LLY,ABBV,MRK,XOM,CVX,OXY,NFLX,DIS,UBER,BA,CAT,WMT,COST
POLYGON_OPTION_BARS_MAX_CONTRACTS=1000

# ── Chat AI ───────────────────────────────────────────────────────────────────
# Set CHAT_PROVIDER to one of: deepseek | mimo | openai | anthropic | ollama
CHAT_PROVIDER=deepseek
CHAT_MODEL=                      # optional — overrides the provider default

# DeepSeek (default) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Xiaomi MiMo — run locally via Ollama (free) or a hosted endpoint
MIMO_API_KEY=                    # leave blank for Ollama; set key for hosted
MIMO_BASE_URL=http://localhost:11434/v1

# OpenAI (GPT-4o / GPT-4o-mini) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Ollama local (no key, fully offline) — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2            # any model pulled via: ollama pull <model>

# ── Paths (optional overrides) ────────────────────────────────────────────────
DB_PATH=./data/ibkr.duckdb
TICKERS_YAML=config/tickers.yaml
